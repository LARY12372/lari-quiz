# Essas variáveis são geradas automaticamente pela Vercel
# quando você conecta o KV Store no painel deles.
# Você NÃO precisa preencher manualmente — a Vercel faz isso.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Crie uma senha forte para acessar o painel admin (só você sabe)
ADMIN_TOKEN=coloque_uma_senha_forte_aqui
